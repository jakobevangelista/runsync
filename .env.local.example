# Local-only Compose and Vite+ development settings. Copy to untracked .env.local.
RUNSYNC_API_HOST=api.runsync.localhost
RUNSYNC_WEB_HOST=live.runsync.localhost
RUNSYNC_PUBLIC_BASE_URL=http://127.0.0.1:8081
RUNSYNC_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://live.runsync.localhost:8080
RUNSYNC_LOG_LEVEL=debug
RUNSYNC_TRUSTED_PROXY_CIDRS=
RUNSYNC_POSTGRES_PASSWORD_FILE=./secrets/postgres_password
RUNSYNC_DATABASE_URL_FILE=./secrets/runsync_database_url
RUNSYNC_VIEWER_TOKEN_SIGNING_KEY_FILE=./secrets/runsync_viewer_token_signing_key
RUNSYNC_CLOUDFLARE_TOKEN_FILE=./secrets/cloudflare_tunnel_token
RUNSYNC_WEB_READ_TOKEN_FILE=./secrets/runsync_web_read_token

# TanStack Start server settings for both Compose and local `vp dev`.
RUNSYNC_API_INTERNAL_URL=http://127.0.0.1:8081
RUNSYNC_API_PUBLIC_URL=http://127.0.0.1:8081
RUNSYNC_API_READ_TOKEN_FILE=../secrets/runsync_web_read_token
RUNSYNC_CHANNEL_SLUG=live
RUNSYNC_OVERLAY_ID=7a85db43-30ba-4de7-bb5e-7f2038937538
RUNSYNC_DEFAULT_UNITS=imperial
RUNSYNC_DEFAULT_PACE=rolling
MAPBOX_ACCESS_TOKEN=
