# Copy values into an untracked .env or your secret manager. These are placeholders, not secrets.
RUNSYNC_API_HOST=runsync-api.example.com
RUNSYNC_WEB_HOST=runsync-live.example.com
RUNSYNC_PUBLIC_BASE_URL=https://runsync-api.example.com
RUNSYNC_ALLOWED_ORIGINS=https://runsync-live.example.com
RUNSYNC_LOG_LEVEL=info
RUNSYNC_TRUSTED_PROXY_CIDRS=
RUNSYNC_POSTGRES_PASSWORD_FILE=./secrets/postgres_password
RUNSYNC_DATABASE_URL_FILE=./secrets/runsync_database_url
RUNSYNC_VIEWER_TOKEN_SIGNING_KEY_FILE=./secrets/runsync_viewer_token_signing_key
RUNSYNC_CLOUDFLARE_TOKEN_FILE=./secrets/cloudflare_tunnel_token
RUNSYNC_WEB_READ_TOKEN_FILE=./secrets/runsync_web_read_token

# TanStack Start server runtime. The read-token path is fixed inside the container.
RUNSYNC_API_PUBLIC_URL=https://runsync-api.example.com
RUNSYNC_CHANNEL_SLUG=live
RUNSYNC_OVERLAY_ID=replace-with-random-uuid
RUNSYNC_DEFAULT_UNITS=imperial
RUNSYNC_DEFAULT_PACE=rolling
MAPBOX_ACCESS_TOKEN=replace-with-hostname-restricted-public-pk-token
